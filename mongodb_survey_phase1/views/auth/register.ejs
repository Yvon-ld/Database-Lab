<%- include('../partials/header') %>
<section class="auth-card">
  <h1>注册账号</h1>
  <form action="/auth/register" method="POST" class="form-grid">
    <label>用户名
      <input type="text" name="username" required minlength="3" maxlength="30" />
    </label>
    <label>密码
      <input type="password" name="password" required minlength="6" />
    </label>
    <button class="btn" type="submit">注册并登录</button>
  </form>
  <p class="hint">已有账号？<a href="/auth/login">去登录</a></p>
</section>
<%- include('../partials/footer') %>
