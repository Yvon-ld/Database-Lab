<%- include('../partials/header') %>
<section class="page-head">
  <div>
    <h1>题库</h1>
    <p>在这里创建可复用的题目版本、按分组整理，并在不同问卷作者之间共享使用。</p>
  </div>
  <div class="button-row">
    <a class="btn" href="/questions/new">新建题目</a>
  </div>
</section>

<div class="builder-shell">
  <div class="builder-main">
    <section class="card">
      <h2>最新可访问题目版本</h2>
      <% if (!catalog.questions.length) { %>
        <p class="muted">暂时还没有可复用题目。</p>
      <% } %>

      <div class="survey-grid">
        <% catalog.questions.forEach((question) => { %>
          <article class="card survey-card compact-card">
            <div class="survey-card-head">
              <h3><%= question.title %></h3>
              <span class="status <%= question.visibility === 'shared' ? 'published' : 'draft' %>">
                v<%= question.version %>
              </span>
            </div>
            <p><%= question.description || '暂无说明' %></p>
            <ul class="meta-list">
              <li><span>题型</span><strong><%= translateQuestionType(question.type) %></strong></li>
              <li><span>归属</span><strong><%= question.isOwner ? '我的' : '共享给我' %></strong></li>
              <li><span>根题目</span><strong><code><%= question.rootQuestionId || question._id %></code></strong></li>
            </ul>
            <div class="button-row wrap">
              <a class="btn btn-secondary" href="/questions/<%= question._id %>">详情</a>
              <a class="btn btn-secondary" href="/surveys/new">用于问卷</a>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  </div>

  <aside class="builder-sidebar">
    <section class="card sticky-card">
      <h2>新建分组</h2>
      <form action="/questions/libraries" method="POST" class="form-grid">
        <label>分组名称
          <input type="text" name="name" required />
        </label>
        <label>分组说明
          <textarea name="description" rows="3"></textarea>
        </label>
        <button class="btn" type="submit">创建分组</button>
      </form>
    </section>

    <section class="card">
      <h2>我的分组</h2>
      <% if (!catalog.libraries.length) { %>
        <p class="muted">暂时还没有分组。</p>
      <% } %>
      <div class="catalog-group">
        <% catalog.libraries.forEach((library) => { %>
          <div class="catalog-library">
            <strong><%= library.name %></strong>
            <p class="muted"><%= library.description || '暂无说明' %></p>
            <div class="catalog-chip-list">
              <% library.questions.forEach((question) => { %>
                <a class="chip-link" href="/questions/<%= question._id %>"><%= question.title %> (v<%= question.version %>)</a>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </section>
  </aside>
</div>
<%- include('../partials/footer') %>
