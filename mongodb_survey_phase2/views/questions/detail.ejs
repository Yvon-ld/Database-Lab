<%- include('../partials/header') %>
<section class="page-head">
  <div>
    <h1><%= question.title %></h1>
    <p>根题目 <code><%= question.rootQuestionId %></code> - 当前版本 <strong>v<%= question.version %></strong></p>
  </div>
  <div class="button-row">
    <a class="btn btn-secondary" href="/questions">返回</a>
    <% if (canManage) { %>
      <a class="btn" href="/questions/<%= question._id %>/new-version">创建新版本</a>
    <% } %>
  </div>
</section>

<div class="builder-shell">
  <div class="builder-main">
    <section class="card">
      <h2>当前版本信息</h2>
      <ul class="meta-list">
        <li><span>题型</span><strong><%= translateQuestionType(question.type) %></strong></li>
        <li><span>可见性</span><strong><%= translateVisibility(question.visibility) %></strong></li>
        <li><span>父版本</span><strong><%= question.parentQuestionId || '无' %></strong></li>
      </ul>
      <p><%= question.description || '暂无说明' %></p>

      <% if (question.options?.length) { %>
        <h3>选项</h3>
        <ul class="stats-list">
          <% question.options.forEach((option) => { %>
            <li><span><%= option.label %></span><strong><code><%= option.optionId %></code></strong></li>
          <% }) %>
        </ul>
      <% } %>
    </section>

    <section class="card">
      <h2>版本历史</h2>
      <div class="stats-list">
        <% history.forEach((item) => { %>
          <div class="history-row">
            <span>v<%= item.version %> - <%= new Date(item.createdAt).toLocaleString('zh-CN', { hour12: false }) %></span>
            <a class="btn btn-secondary" href="/questions/<%= item._id %>">打开</a>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="card">
      <h2>被哪些问卷使用</h2>
      <% if (!usage.length) { %>
        <p class="muted">这个题目根版本暂时还没有被任何问卷使用。</p>
      <% } %>
      <div class="stats-list">
        <% usage.forEach((survey) => { %>
          <div class="history-row">
            <span><%= survey.title %> - <%= translateSurveyStatus(survey.status) %></span>
            <a class="btn btn-secondary" href="/surveys/<%= survey._id %>/stats">问卷统计</a>
          </div>
        <% }) %>
      </div>
    </section>

    <section class="card">
      <h2>跨问卷统计</h2>
      <p>总回答数：<strong><%= crossSurveyStats.totalResponses %></strong></p>
      <% if (crossSurveyStats.optionCounts) { %>
        <ul class="stats-list">
          <% crossSurveyStats.optionCounts.forEach((option) => { %>
            <li><span><%= option.label %></span><strong><%= option.count %></strong></li>
          <% }) %>
        </ul>
      <% } else if (question.type === 'number') { %>
        <p>平均值：<%= crossSurveyStats.average === null ? '暂无' : crossSurveyStats.average.toFixed(2) %></p>
        <pre><%= JSON.stringify(crossSurveyStats.values, null, 2) %></pre>
      <% } else { %>
        <pre><%= JSON.stringify(crossSurveyStats.values || [], null, 2) %></pre>
      <% } %>
    </section>
  </div>

  <aside class="builder-sidebar">
    <% if (canManage) { %>
      <section class="card sticky-card">
        <h2>共享这个题目根版本</h2>
        <form action="/questions/<%= question._id %>/share" method="POST" class="form-grid">
          <label>目标用户名
            <input type="text" name="username" required />
          </label>
          <button class="btn" type="submit">共享</button>
        </form>
      </section>
    <% } %>

    <section class="card">
      <h2>加入题库分组</h2>
      <% if (!libraries.length) { %>
        <p class="muted">请先去题库页面创建分组。</p>
      <% } %>
      <% libraries.forEach((library) => { %>
        <div class="catalog-library">
          <strong><%= library.name %></strong>
          <p class="muted"><%= library.description || '暂无说明' %></p>
          <% if (library.containsQuestion) { %>
            <form action="/questions/libraries/<%= library._id %>/questions/<%= question.rootQuestionId %>/remove" method="POST">
              <button class="btn btn-danger" type="submit">从分组中移除</button>
            </form>
          <% } else { %>
            <form action="/questions/libraries/<%= library._id %>/questions" method="POST">
              <input type="hidden" name="questionId" value="<%= question._id %>" />
              <button class="btn btn-secondary" type="submit">加入分组</button>
            </form>
          <% } %>
        </div>
      <% }) %>
    </section>
  </aside>
</div>
<%- include('../partials/footer') %>
